# ============================================
# VIDEO EDITOR API - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and fill in your actual values
# Required variables are marked with [REQUIRED]
# Optional variables are marked with [OPTIONAL]

# ============================================
# SERVER CONFIGURATION [REQUIRED]
# ============================================
PORT=8080
NODE_ENV=development
API_URL=http://localhost:8080

# ============================================
# DATABASE - SUPABASE [REQUIRED]
# ============================================
# Get these from: https://supabase.com/dashboard
# 1. Go to project settings
# 2. Copy the API URL and anon key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here

# ============================================
# JWT AUTHENTICATION [REQUIRED]
# ============================================
# Generate secure secret keys (minimum 32 characters)
# You can use: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_minimum_32_characters_long_change_this_in_production
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d

# ============================================
# GOOGLE OAUTH 2.0 [OPTIONAL]
# ============================================
# Get these from: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable "Google+ API"
# 3. Go to Credentials → Create OAuth 2.0 Client ID (Desktop/Web Application)
# 4. Add authorized redirect URI: http://localhost:3000/api/auth/google/callback
# Leave empty if you're not using Google OAuth yet
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ============================================
# VIDEO PROCESSING CONFIGURATION [OPTIONAL]
# ============================================
# MAIN_VIDEO_HEIGHT_PERCENT: How much of screen the main video takes (1-100)
# SPLIT_POSITIONS: Comma-separated list of positions (top, bottom, left, right)
MAIN_VIDEO_HEIGHT_PERCENT=80
SPLIT_POSITIONS=top,bottom

# ============================================
# ENCRYPTION [REQUIRED]
# ============================================
# 32-character hex string for encrypting sensitive data
# Generate with: `node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"`
ENCRYPTION_KEY=c7967834a8145e044b3677287ba5e873

# ============================================
# CORS CONFIGURATION [REQUIRED]
# ============================================
# Comma-separated list of allowed origins for frontend
# For development: http://localhost:3001,http://localhost:3000
# For production: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# ============================================
# API KEYS MANAGEMENT [OPTIONAL]
# ============================================
# NOTE: YouTube and Facebook API keys are NOT stored in .env
# Users manage their own API keys through the REST API:
# - POST /api/users/api-keys - Add a new API key
# - GET /api/users/api-keys - List user's API keys
# - DELETE /api/users/api-keys/:id - Remove an API key
# - POST /api/users/api-keys/:id/test - Test key validity

# ============================================
# QUICK START CHECKLIST
# ============================================
# Before running the server:
#
# 1. [ ] Update PORT (default 3000 is fine for development)
# 2. [ ] Set NODE_ENV (use 'development' for testing, 'production' for deployment)
# 3. [ ] Add SUPABASE_URL and SUPABASE_KEY (REQUIRED for database access)
# 4. [ ] Generate and add JWT_SECRET and JWT_REFRESH_SECRET (REQUIRED)
# 5. [ ] Configure GOOGLE_CLIENT_ID/SECRET if using Google OAuth (optional)
# 6. [ ] Update CORS_ORIGIN to match your frontend URL
# 7. [ ] Generate ENCRYPTION_KEY for secure data storage
#
# Then run: npm install && npm start
#
# Verify server is running:
# curl http://localhost:3000/api/health
